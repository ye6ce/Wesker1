{
  "entities": {
    "projectRequest": {
      "title": "Project Request",
      "description": "A lead generated from the pricing questionnaire",
      "type": "object",
      "properties": {
        "service": { "type": "string" },
        "language": { "type": "string" },
        "answers": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "contacted", "closed"] }
      },
      "required": ["service", "language", "answers", "createdAt", "status"]
    }
  },
  "firestore": {
    "/requests/{requestId}": {
      "schema": "projectRequest",
      "description": "Collection of lead requests from the quiz"
    }
  }
}
